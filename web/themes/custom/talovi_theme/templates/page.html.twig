{#
/**
 * @file
 * Theme override to display a single page.
 *
 * @see template_preprocess_page()
 */
#}
<div class="layout-container">

  <header class="talovi-header" role="banner">
    <a class="talovi-logo" href="{{ path('<front>') }}" rel="home">
      <img class="talovi-logo-icon" src="/themes/custom/talovi_theme/images/talovi-logo-icon.png" srcset="/themes/custom/talovi_theme/images/talovi-logo-icon-2x.png 2x" width="32" height="32" alt="Talovi">
      <span class="talovi-logo-text">Talovi<sup style="font-size:0.5em;vertical-align:super;">&#8482;</sup></span>
    </a>

    <nav class="talovi-nav" role="navigation" aria-label="{{ 'Main navigation'|t }}">
      <ul>
        <li><a href="/">{{ 'Home'|t }}</a></li>
        <li><a href="/docs">{{ 'Docs'|t }}</a></li>
        <li><a href="/blog">{{ 'Blog'|t }}</a></li>
        <li><a href="https://cloud.talovi.dev" class="nav-cloud">{{ 'Cloud'|t }}</a></li>
        <li><a href="/about">{{ 'About'|t }}</a></li>
        <li><a href="https://github.com/Talovi/talovi" target="_blank" rel="noopener noreferrer">{{ 'GitHub'|t }}</a></li>
        <li><a href="/getting-started" class="btn-nav-primary">{{ 'Get started'|t }}</a></li>
      </ul>
    </nav>

    <button class="hamburger" aria-label="{{ 'Toggle menu'|t }}" aria-expanded="false">
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
      <span class="hamburger-bar"></span>
    </button>
  </header>

  {% if is_front %}
  <section class="talovi-hero">
    <div class="hero-glow" aria-hidden="true"></div>
    <div class="hero-inner">
      <h2>{{ 'AI for everyone. No coding required.'|t }}</h2>
      <p>{{ 'Talovi gives your business an intelligent AI assistant that understands your industry — whether you\'re a business owner with no technical background, or a developer building something new.'|t }}</p>
      <div class="hero-ctas">
        <a href="/demo" class="btn-primary">{{ 'Try the live demo'|t }}</a>
        <a href="/getting-started" class="btn-outline">{{ 'Get started free'|t }}</a>
      </div>
    </div>
  </section>

  <section class="home-audience">
    <div class="container">
      <div class="audience-grid">

        <div class="audience-card">
          <div class="audience-label">{{ 'For business owners'|t }}</div>
          <h2>{{ 'You don\'t need a developer to add AI to your business.'|t }}</h2>
          <p>{{ 'Talovi works right in your browser. Choose your industry, enter your API key, and your AI assistant is ready — no installation, no coding, no technical knowledge required.'|t }}</p>
          <p class="audience-subline">{{ 'Works for: Medical practices, law offices, real estate agencies, retail stores, and more.'|t }}</p>
          <ul class="benefit-list">
            <li>{{ 'Answer customer questions 24/7'|t }}</li>
            <li>{{ 'Handle appointment requests and inquiries'|t }}</li>
            <li>{{ 'Guide visitors to the right service'|t }}</li>
            <li>{{ 'Works on any website'|t }}</li>
            <li>{{ 'No coding or technical knowledge required'|t }}</li>
            <li>{{ 'Available in English, Spanish, French, Portuguese, and Chinese — with automatic language detection'|t }}</li>
          </ul>
          <a href="/demo" class="btn-primary">{{ 'Try a live demo — no signup required'|t }}</a>
        </div>

        <div class="audience-card">
          <div class="audience-label">{{ 'For developers'|t }}</div>
          <h2>{{ 'Build AI-powered apps in minutes, not months.'|t }}</h2>
          <p>{{ 'Talovi handles provider switching, agent routing, conversation memory, and cost tracking. You focus on your product.'|t }}</p>
          <ul class="benefit-list">
            <li>{{ 'Works with Claude, ChatGPT, Gemini, Grok, and Ollama'|t }}</li>
            <li>{{ '5 domain agents ready to deploy'|t }}</li>
            <li>{{ 'Switch AI providers in one line'|t }}</li>
            <li>{{ 'Built-in cost tracking across all providers'|t }}</li>
            <li>{{ 'MIT licensed, free forever'|t }}</li>
          </ul>
          <pre class="npm-install"><code>npm install talovi</code></pre>
          <a href="/docs" class="btn-outline">{{ 'Read the docs'|t }}</a>
        </div>

      </div>
    </div>
  </section>

  <section class="home-how">
    <div class="container">
      <h2>{{ 'How Talovi works'|t }}</h2>
      <div class="steps-grid">
        <div class="step">
          <div class="step-number">1</div>
          <h3>{{ 'Choose your AI provider'|t }}</h3>
          <p>{{ 'Pick Claude, Gemini, Grok, or run locally with Ollama. Bring your own API key — no middleman, no markup.'|t }}</p>
        </div>
        <div class="step">
          <div class="step-number">2</div>
          <h3>{{ 'Select your domain'|t }}</h3>
          <p>{{ 'Healthcare, Legal, Real Estate, Retail, or General. Each agent has deep domain knowledge built in.'|t }}</p>
        </div>
        <div class="step">
          <div class="step-number">3</div>
          <h3>{{ 'Deploy anywhere'|t }}</h3>
          <p>{{ 'Embed on your website, integrate into your app, or deploy as a standalone assistant. One script tag or npm install.'|t }}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="home-mission">
    <div class="container">
      <blockquote>
        {{ '"We believe AI should be a level playing field. The corner shop owner, the independent pharmacist, the first-generation developer — they deserve the same tools as Fortune 500 companies."'|t }}
      </blockquote>
      <cite>{{ '— IT Lasso, Canton Ohio'|t }}</cite>
    </div>
  </section>

  <section class="home-blog">
    <div class="container">
      <p class="home-blog-label">{{ 'From the blog'|t }}</p>
      <div class="home-blog-card">
        <div class="home-blog-card-body">
          <h3><a href="/blog/talovi-is-live">{{ 'Talovi Is Live — AI for Everyone, Starting Today'|t }}</a></h3>
          <p>{{ 'We built Talovi because big companies were deploying AI assistants while small business owners were left behind. That ends today.'|t }}</p>
        </div>
        <a href="/blog/talovi-is-live" class="home-blog-card-link">{{ 'Read the launch post →'|t }}</a>
      </div>
    </div>
  </section>

  <section class="home-cta">
    <div class="container">
      <div class="cta-grid">
        <div class="cta-card">
          <h3>{{ 'Try it now'|t }}</h3>
          <p>{{ 'See Talovi in action with a live demo — no signup required.'|t }}</p>
          <a href="/demo" class="btn-primary">{{ 'Launch demo'|t }}</a>
        </div>
        <div class="cta-card">
          <h3>{{ 'Start building'|t }}</h3>
          <p>{{ 'Install Talovi and deploy your first agent in 30 minutes.'|t }}</p>
          <pre><code>npm install talovi</code></pre>
          <a href="/getting-started" class="btn-outline">{{ 'Get started'|t }}</a>
        </div>
      </div>
    </div>
  </section>
  {% endif %}

  {% if not is_front %}
  <div class="page-title-bar">
    <div class="container">
      {% if node %}
        <h1 class="page-title">{{ node.label }}</h1>
      {% elseif page.page_title %}
        {{ page.page_title }}
      {% endif %}
    </div>
  </div>

  <main id="main-content" class="main-content" role="main">
    <div class="container">
      {{ page.content }}
    </div>
  </main>
  {% endif %}

  <footer class="site-footer" role="contentinfo">
    <div class="container footer-inner">
      {% if page.footer %}
        {{ page.footer }}
      {% else %}
        <div class="footer-grid">
          <div class="footer-col">
            <h4 class="footer-heading">{{ 'About Talovi™'|t }}</h4>
            <p class="footer-text">{{ 'Open source AI framework built for developers who believe technology should be accessible to everyone.'|t }}</p>
          </div>
          <div class="footer-col">
            <h4 class="footer-heading">{{ 'Links'|t }}</h4>
            <ul class="footer-links">
              <li><a href="/docs">{{ 'Documentation'|t }}</a></li>
              <li><a href="/community">{{ 'Community'|t }}</a></li>
              <li><a href="/blog">{{ 'Blog'|t }}</a></li>
              <li><a href="/license">{{ 'License'|t }}</a></li>
              <li><a href="https://github.com/Talovi/talovi" target="_blank" rel="noopener noreferrer">{{ 'GitHub'|t }}</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4 class="footer-heading">{{ 'By IT Lasso'|t }}</h4>
            <p class="footer-text">{{ 'Built and maintained by IT Lasso. Empowering communities through open technology.'|t }}</p>
            <a href="https://itlasso.com" class="footer-link-external" target="_blank" rel="noopener noreferrer">itlasso.com</a>
          </div>
        </div>
        <div class="footer-bottom">
          <p class="footer-copy">{{ 'Talovi™ — MIT License — by IT Lasso'|t }}</p>
        </div>
      {% endif %}
    </div>
  </footer>

</div>{# /.layout-container #}

{% if is_demo %}
{#
  Demo page widget controls.
  embed.js is NOT loaded on page load — it is injected dynamically only after
  the user clicks "Start demo". This prevents the widget from auto-launching
  and ensures TaloviConfig is set before the IIFE runs.
  The language switcher is also hidden until after launch.
#}


{# Language switcher — hidden until after Start demo is clicked #}
<div id="talovi-demo-lang" style="display:none;position:fixed;bottom:20px;right:84px;z-index:9997;background:#1a1e2a;border:1px solid rgba(255,255,255,.15);border-radius:10px;padding:8px 12px;font-family:system-ui,sans-serif;font-size:.78rem;color:#e6edf3;box-shadow:0 4px 16px rgba(0,0,0,.4);">
  <label for="talovi-ext-lang" style="display:flex;align-items:center;gap:8px;cursor:pointer;white-space:nowrap;">
    <span>&#127760; Language:</span>
    <select id="talovi-ext-lang" style="background:#0d1117;border:1px solid rgba(255,255,255,.2);color:#e6edf3;border-radius:6px;padding:3px 8px;font-size:.78rem;cursor:pointer;">
      <option value="en">English</option>
      <option value="es">Espa&#241;ol</option>
      <option value="fr">Fran&#231;ais</option>
      <option value="pt">Portugu&#234;s</option>
      <option value="zh">&#20013;&#25991;</option>
    </select>
  </label>
</div>

<script>
(function () {
  var extSel = document.getElementById('talovi-ext-lang');

  // Hook into the node body's startDemo() without touching the node HTML.
  // We wait for DOMContentLoaded so the node body script has already defined
  // window.startDemo before we wrap it.
  document.addEventListener('DOMContentLoaded', function () {
    var _orig = window.startDemo;
    window.startDemo = function () {
      if (_orig) _orig.apply(this, arguments);
      var langCtrl = document.getElementById('talovi-demo-lang');
      if (langCtrl) langCtrl.style.display = 'block';
    };
  });

  // Language strings for the inline chat box
  var greetings = {
    en: 'Hello! How can I help you today?',
    es: '\u00a1Hola! \u00bfC\u00f3mo puedo ayudarte hoy?',
    fr: 'Bonjour\u00a0! Comment puis-je vous aider aujourd\u2019hui\u00a0?',
    pt: 'Ol\u00e1! Como posso ajud\u00e1-lo hoje?',
    zh: '\u4f60\u597d\uff01\u4eca\u5929\u6211\u80fd\u5e2e\u4f60\u4ec0\u4e48\uff1f'
  };
  var placeholders = {
    en: 'Ask something\u2026',
    es: 'Escribe tu mensaje\u2026',
    fr: '\u00c9crivez votre message\u2026',
    pt: 'Digite sua mensagem\u2026',
    zh: '\u8f93\u5165\u6d88\u606f\u2026'
  };

  if (extSel) {
    extSel.addEventListener('change', function () {
      var lang = this.value;
      var chatInput = document.getElementById('chatInput');
      var chatMessages = document.getElementById('chatMessages');
      if (chatInput) chatInput.placeholder = placeholders[lang] || placeholders.en;
      if (chatMessages) {
        var firstMsg = chatMessages.querySelector('.chat-msg.assistant');
        if (firstMsg) firstMsg.textContent = greetings[lang] || greetings.en;
      }
    });
  }
})();
</script>
{% endif %}
